# Copy to ".env" and adjust. Lines are optional unless noted for your setup.
# Vite (apps/web) — see https://vitejs.dev/guide/env-and-mode.html

# Optional: HTTP API base for the web client (empty = same origin)
# VITE_API_URL=

# GitHub account sign-in (Settings → General). Register the callback URL in the GitHub OAuth App:
#   {PUBLIC_ORIGIN}/api/auth/github/callback   e.g. http://127.0.0.1:3000/api/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# AUTH_SESSION_SECRET=change-me-to-a-long-random-string
# Optional: extra SPA origins allowed for the post-login redirect (comma-separated)
# AUTH_REDIRECT_ORIGINS=http://127.0.0.1:5173

# Optional: Playwright when the dev server is already running elsewhere
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Server / TanStack (local dev)
# PORT=3000

# --- AI and agents (set only what you use) ---
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Codex CLI home override
# CODEX_HOME=

# Dev-only: allow local ACP connections (server checks this)
# OPENPENCIL_ALLOW_LOCAL_ACP=1

# Electron packaging (when building desktop)
# ELECTRON_RESOURCES_PATH=
